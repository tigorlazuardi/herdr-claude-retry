{
  "name": "@tigorhutasuhut/herdr-claude-retry",
  "version": "0.1.8",
  "description": "Herdr daemon — monitor Claude CLI sessions and auto-retry on rate-limit and errors",
  "type": "module",
  "license": "MIT",
  "author": "Tigor Hutasuhut <tigor.hutasuhut@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tigorlazuardi/herdr-claude-retry.git"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "bin": {
    "herdr-claude-retry": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test 'test/**/*.test.ts'",
    "e2e": "node --test 'test/e2e/*.e2e.ts'",
    "verify": "npm run typecheck && npm test && npm run build",
    "prepublishOnly": "npm run verify"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "^5.0.0"
  }
}
